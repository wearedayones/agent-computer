#!/bin/bash
# fleet — run commands across all sync peers in parallel
# Usage: axis fleet status
#        axis fleet run "<command>"
#        axis fleet alert
#        axis fleet push skill/<name> [<alias>...]
#        axis fleet list

PEERS_FILE="$HOME/system/sync-peers.json"
GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; DIM='\033[2m'; CYAN='\033[0;36m'; NC='\033[0m'

[ -f "$PEERS_FILE" ] || echo '{"peers":{}}' > "$PEERS_FILE"

get_peers() {
  python3 -c "
import json
from pathlib import Path
d = json.loads(Path('$PEERS_FILE').read_text())
for alias, p in d.get('peers', {}).items():
    print(alias + '|' + p['host'])
" 2>/dev/null
}

run_on_peer() {
  local alias="$1" host="$2" cmd="$3"
  local out
  out=$(ssh -o ConnectTimeout=8 -o BatchMode=yes -o StrictHostKeyChecking=no \
        "$host" "bash -lc '$cmd' 2>&1" 2>&1)
  local exit_code=$?
  if [ $exit_code -eq 0 ]; then
    echo "__PEER_START__${alias}__OK__"
  else
    echo "__PEER_START__${alias}__FAIL__"
  fi
  echo "$out"
  echo "__PEER_END__"
}

print_results() {
  python3 - <<'EOF'
import sys, re
CYAN, GREEN, RED, BOLD, DIM, NC = "\033[0;36m","\033[0;32m","\033[0;31m","\033[1m","\033[2m","\033[0m"
content = sys.stdin.read()
blocks = re.findall(r'__PEER_START__(\w[\w-]*)__(OK|FAIL)__(.*?)__PEER_END__', content, re.DOTALL)
for alias, status, output in blocks:
    col = GREEN if status == "OK" else RED
    print(f"\n  {col}{'●' if status=='OK' else '✗'}{NC}  {BOLD}{alias}{NC}  {DIM}({status}){NC}")
    for line in output.strip().splitlines():
        print(f"     {line}")
print("")
EOF
}

cmd="${1:-list}"

case "$cmd" in
  list)
    peers=$(get_peers)
    if [ -z "$peers" ]; then
      echo -e "\n  (no peers — add with: axis sync peer add <alias> <user@host>)\n"
      exit 0
    fi
    echo ""
    echo -e "  ${BOLD}Fleet Members${NC}\n"
    while IFS='|' read -r alias host; do
      echo -e "  ${CYAN}${alias}${NC}  →  $host"
    done <<< "$peers"
    echo ""
    ;;

  status)
    peers=$(get_peers)
    if [ -z "$peers" ]; then
      echo -e "\n  (no peers configured)\n"; exit 0
    fi
    echo -e "\n  ${BOLD}Fleet Status${NC}\n"
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT
    # Run all pings in parallel
    while IFS='|' read -r alias host; do
      (
        out=$(ssh -o ConnectTimeout=6 -o BatchMode=yes "$host" \
          "bash -lc 'echo \$(cat ~/system/.version 2>/dev/null || echo ?)||\$(df -h ~ 2>/dev/null | tail -1 | awk \"{print \\\$5}\")|||\$(python3 -c \"import json; d=json.load(open(chr(126)+\\\"/system/tasks.json\\\")); print(len([t for t in d[\\\"tasks\\\"] if t[\\\"status\\\"]==\\\"open\\\"]))\" 2>/dev/null || echo ?)'" 2>/dev/null)
        if [ $? -eq 0 ]; then
          version=$(echo "$out" | cut -d'|' -f1)
          disk=$(echo "$out" | cut -d'|' -f2)
          tasks=$(echo "$out" | cut -d'|' -f3)
          echo -e "  ${GREEN}✓${NC}  ${CYAN}${alias}${NC}  v${version}  disk ${disk}  tasks ${tasks} open" > "$tmpdir/$alias"
        else
          echo -e "  ${RED}✗${NC}  ${CYAN}${alias}${NC}  unreachable" > "$tmpdir/$alias"
        fi
      ) &
    done
    wait
    # Print in peer order
    while IFS='|' read -r alias host; do
      cat "$tmpdir/$alias" 2>/dev/null || echo -e "  ${RED}✗${NC}  ${CYAN}${alias}${NC}  no response"
    done <<< "$peers"
    echo ""
    ;;

  run)
    remote_cmd="${2:-}"
    [ -z "$remote_cmd" ] && { echo 'Usage: axis fleet run "<command>"'; exit 1; }
    peers=$(get_peers)
    if [ -z "$peers" ]; then
      echo -e "\n  (no peers configured)\n"; exit 0
    fi
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT
    echo -e "\n  ${BOLD}Fleet run:${NC} $remote_cmd\n"
    while IFS='|' read -r alias host; do
      ( run_on_peer "$alias" "$host" "$remote_cmd" > "$tmpdir/$alias" ) &
    done
    wait
    while IFS='|' read -r alias host; do
      cat "$tmpdir/$alias" 2>/dev/null
    done <<< "$peers" | print_results
    ;;

  alert)
    peers=$(get_peers)
    if [ -z "$peers" ]; then
      echo -e "\n  (no peers configured)\n"; exit 0
    fi
    echo -e "\n  ${BOLD}Fleet Alerts${NC}\n"
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT
    while IFS='|' read -r alias host; do
      (
        out=$(ssh -o ConnectTimeout=8 -o BatchMode=yes "$host" \
          "bash -lc 'axis alert 2>/dev/null || echo \"(no axis)\"'" 2>/dev/null)
        echo "__PEER_START__${alias}__OK__"
        echo "$out"
        echo "__PEER_END__"
      ) > "$tmpdir/$alias" &
    done
    wait
    while IFS='|' read -r alias host; do
      cat "$tmpdir/$alias" 2>/dev/null
    done <<< "$peers" | print_results
    ;;

  push)
    item="${2:-}"
    [ -z "$item" ] && { echo "Usage: axis fleet push <skill|system/file> [<alias>...]"; exit 1; }
    shift 2
    targets=("$@")
    # Default: all peers
    if [ ${#targets[@]} -eq 0 ]; then
      while IFS='|' read -r alias host; do
        targets+=("$alias")
      done <<< "$(get_peers)"
    fi
    src="$HOME/$item"
    [ -f "$src" ] || { echo "  (not found: ~/$item)"; exit 1; }
    for alias in "${targets[@]}"; do
      host=$(python3 -c "
import json
from pathlib import Path
d = json.loads(Path('$PEERS_FILE').read_text())
p = d.get('peers', {}).get('$alias')
print(p['host'] if p else '')
" 2>/dev/null)
      if [ -z "$host" ]; then
        echo -e "  ${YELLOW}⚠${NC}  Unknown peer: $alias"; continue
      fi
      if rsync -az "$src" "$host:~/$item" 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC}  $alias ← $item"
      else
        echo -e "  ${RED}✗${NC}  $alias push failed"
      fi
    done
    ;;

  *)
    echo "Usage: axis fleet list|status|run|alert|push <args>"
    exit 1
    ;;
esac
