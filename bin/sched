#!/bin/bash
# sched — named cron jobs with run history (Agent Computer v4)
# Usage: sched add "every 5min" "bash ~/scripts/foo.sh" --name health-check
#        sched list
#        sched log <name> [N]
#        sched run <name>
#        sched pause <name>
#        sched resume <name>
#        sched del <name>

STORE="$HOME/system/sched.json"
RUNLOG="$HOME/system/sched-log.jsonl"
WRAPPER="$HOME/system/sched-run.sh"

GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; DIM='\033[2m'; CYAN='\033[0;36m'; NC='\033[0m'

[ -f "$STORE" ] || echo '{"jobs":[]}' > "$STORE"
touch "$RUNLOG"

# ── Natural language schedule → cron expression ───────────────────────────────
parse_schedule() {
  local s="$1"
  # every N min(utes)
  if echo "$s" | grep -qiE "^every ([0-9]+) ?min"; then
    n=$(echo "$s" | grep -oE "[0-9]+" | head -1)
    echo "*/$n * * * *"; return
  fi
  # every N hour(s)
  if echo "$s" | grep -qiE "^every ([0-9]+) ?hour"; then
    n=$(echo "$s" | grep -oE "[0-9]+" | head -1)
    echo "0 */$n * * *"; return
  fi
  # every hour
  if echo "$s" | grep -qiE "^every hour$"; then
    echo "0 * * * *"; return
  fi
  # every day at HH:MM
  if echo "$s" | grep -qiE "^every day at [0-9]{1,2}:[0-9]{2}"; then
    hm=$(echo "$s" | grep -oE "[0-9]{1,2}:[0-9]{2}")
    h=$(echo "$hm" | cut -d: -f1); m=$(echo "$hm" | cut -d: -f2)
    echo "$m $h * * *"; return
  fi
  # every weekday at HH:MM
  if echo "$s" | grep -qiE "^every weekday at [0-9]{1,2}:[0-9]{2}"; then
    hm=$(echo "$s" | grep -oE "[0-9]{1,2}:[0-9]{2}")
    h=$(echo "$hm" | cut -d: -f1); m=$(echo "$hm" | cut -d: -f2)
    echo "$m $h * * 1-5"; return
  fi
  # every week on <day> at HH:MM
  if echo "$s" | grep -qiE "^every week on (mon|tue|wed|thu|fri|sat|sun)"; then
    day=$(echo "$s" | grep -oiE "(mon|tue|wed|thu|fri|sat|sun)" | head -1 | tr '[:upper:]' '[:lower:]')
    hm=$(echo "$s" | grep -oE "[0-9]{1,2}:[0-9]{2}")
    h=$(echo "$hm" | cut -d: -f1); m=$(echo "$hm" | cut -d: -f2)
    echo "$m $h * * $day"; return
  fi
  # fall back: treat as raw cron expression (5 fields)
  echo "$s"
}

cmd="${1:-list}"

case "$cmd" in
  add)
    shift
    schedule="${1:-}"; shift
    job_cmd="${1:-}"; shift
    [ -z "$schedule" ] || [ -z "$job_cmd" ] && {
      echo "Usage: axis sched add \"<schedule>\" \"<command>\" --name <name>"
      exit 1
    }
    name=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --name) name="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    [ -z "$name" ] && name="job-$(date +%s)"
    cron_expr=$(parse_schedule "$schedule")
    cron_line="$cron_expr bash $WRAPPER $name $job_cmd"

    python3 - "$STORE" "$name" "$schedule" "$cron_expr" "$job_cmd" <<'EOF'
import json, sys
from datetime import datetime, timezone
from pathlib import Path
store, name, sched_human, cron_expr, cmd = sys.argv[1:6]
d = json.loads(Path(store).read_text())
for j in d["jobs"]:
    if j["name"] == name:
        print(f"  Job '{name}' already exists — use sched del first")
        sys.exit(1)
d["jobs"].append({
    "name": name,
    "schedule_human": sched_human,
    "cron": cron_expr,
    "cmd": cmd,
    "paused": False,
    "created": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "last_run": None,
    "last_exit": None,
})
Path(store).write_text(json.dumps(d, indent=2))
EOF

    # Add to crontab
    CRONTAB=$(crontab -l 2>/dev/null || echo "")
    if echo "$CRONTAB" | grep -qF "sched-run.sh $name "; then
      echo -e "  ${YELLOW}⚠${NC}  Cron entry for '$name' already exists"
    else
      (echo "$CRONTAB"; echo "$cron_line") | crontab -
      echo -e "  ${GREEN}✓${NC}  Job '$name' scheduled: $schedule  ${DIM}[$cron_expr]${NC}"
    fi
    ;;

  list)
    python3 - "$STORE" "$RUNLOG" <<'EOF'
import json, sys
from pathlib import Path
from datetime import datetime, timezone

store, runlog = sys.argv[1:3]
BOLD, GREEN, RED, YELLOW, DIM, CYAN, NC = \
    "\033[1m","\033[0;32m","\033[0;31m","\033[1;33m","\033[2m","\033[0;36m","\033[0m"

d = json.loads(Path(store).read_text())
jobs = d.get("jobs", [])
if not jobs:
    print("\n  (no scheduled jobs — add with: axis sched add)\n")
    sys.exit(0)

# Last exit per job from runlog
last_exits = {}
try:
    for line in Path(runlog).read_text().splitlines():
        if not line.strip(): continue
        e = json.loads(line)
        last_exits[e["name"]] = e
except: pass

print(f"\n  {BOLD}Scheduled Jobs{NC}\n")
print(f"  {'NAME':<22}  {'SCHEDULE':<22}  {'LAST RUN':<12}  STATUS")
print(f"  {'─'*72}")
for j in jobs:
    name = j["name"]
    sched = j.get("schedule_human", j.get("cron","?"))[:22]
    lr = j.get("last_run") or "never"
    if lr != "never":
        lr = lr[:10]
    paused = j.get("paused", False)
    le = last_exits.get(name)
    if paused:
        status = f"{YELLOW}PAUSED{NC}"
    elif le:
        ok = le.get("ok", le.get("exit_code",1)==0)
        dur = le.get("duration_s", 0)
        status = f"{GREEN}OK{NC} ({dur}s)" if ok else f"{RED}FAIL (exit {le.get('exit_code','?')}){NC}"
    else:
        status = f"{DIM}never run{NC}"
    print(f"  {CYAN}{name:<22}{NC}  {sched:<22}  {lr:<12}  {status}")
print("")
EOF
    ;;

  log)
    name="${2:-}"
    limit="${3:-10}"
    [ -z "$name" ] && { echo "Usage: axis sched log <name> [N]"; exit 1; }
    python3 - "$RUNLOG" "$name" "$limit" <<'EOF'
import json, sys
from pathlib import Path
BOLD,GREEN,RED,DIM,NC = "\033[1m","\033[0;32m","\033[0;31m","\033[2m","\033[0m"
runlog, name, limit = Path(sys.argv[1]), sys.argv[2], int(sys.argv[3])
try:
    entries = [json.loads(l) for l in runlog.read_text().splitlines() if l.strip()]
    entries = [e for e in entries if e.get("name") == name]
except:
    entries = []
if not entries:
    print(f"  (no run history for '{name}')"); sys.exit(0)
print(f"\n  {BOLD}Run history: {name} (last {limit}){NC}\n")
print(f"  {'TIME':<20}  {'EXIT':>4}  {'DURATION':>8}  STATUS")
print(f"  {'─'*48}")
for e in entries[-limit:]:
    ts = e.get("ts","?")[:16].replace("T"," ")
    ex = e.get("exit_code","?")
    dur = f"{e.get('duration_s',0)}s"
    ok = e.get("ok", ex == 0)
    sc = f"{GREEN}OK{NC}" if ok else f"{RED}FAIL{NC}"
    print(f"  {ts:<20}  {str(ex):>4}  {dur:>8}  {sc}")
print("")
EOF
    ;;

  run)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis sched run <name>"; exit 1; }
    job_cmd=$(python3 -c "
import json
from pathlib import Path
d = json.loads(Path('$STORE').read_text())
j = next((j for j in d['jobs'] if j['name'] == '$name'), None)
print(j['cmd'] if j else '')
")
    if [ -z "$job_cmd" ]; then
      echo "  (job '$name' not found)"; exit 1
    fi
    echo -e "  ${DIM}Running '$name'...${NC}"
    bash "$WRAPPER" "$name" $job_cmd
    echo -e "  ${GREEN}✓${NC}  Done"
    ;;

  pause)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis sched pause <name>"; exit 1; }
    # Remove from crontab
    CRONTAB=$(crontab -l 2>/dev/null || echo "")
    echo "$CRONTAB" | grep -vF "sched-run.sh $name " | crontab -
    python3 - "$STORE" "$name" "true" <<'EOF'
import json, sys
from pathlib import Path
store, name, paused = sys.argv[1:4]
d = json.loads(Path(store).read_text())
for j in d["jobs"]:
    if j["name"] == name:
        j["paused"] = paused == "true"
Path(store).write_text(json.dumps(d, indent=2))
EOF
    echo -e "  ${YELLOW}⚠${NC}  '$name' paused (cron entry removed)"
    ;;

  resume)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis sched resume <name>"; exit 1; }
    job=$(python3 -c "
import json
from pathlib import Path
d = json.loads(Path('$STORE').read_text())
j = next((j for j in d['jobs'] if j['name'] == '$name'), None)
if j: print(j['cron'] + ' bash $WRAPPER ' + '$name' + ' ' + j['cmd'])
")
    if [ -z "$job" ]; then
      echo "  (job '$name' not found)"; exit 1
    fi
    CRONTAB=$(crontab -l 2>/dev/null || echo "")
    if echo "$CRONTAB" | grep -qF "sched-run.sh $name "; then
      echo "  (already active)"
    else
      (echo "$CRONTAB"; echo "$job") | crontab -
    fi
    python3 - "$STORE" "$name" "false" <<'EOF'
import json, sys
from pathlib import Path
store, name, paused = sys.argv[1:4]
d = json.loads(Path(store).read_text())
for j in d["jobs"]:
    if j["name"] == name:
        j["paused"] = False
Path(store).write_text(json.dumps(d, indent=2))
EOF
    echo -e "  ${GREEN}✓${NC}  '$name' resumed"
    ;;

  del|delete|rm)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis sched del <name>"; exit 1; }
    CRONTAB=$(crontab -l 2>/dev/null || echo "")
    echo "$CRONTAB" | grep -vF "sched-run.sh $name " | crontab -
    python3 - "$STORE" "$name" <<'EOF'
import json, sys
from pathlib import Path
store, name = sys.argv[1:3]
d = json.loads(Path(store).read_text())
before = len(d["jobs"])
d["jobs"] = [j for j in d["jobs"] if j["name"] != name]
if len(d["jobs"]) == before:
    print(f"  (job '{name}' not found)"); sys.exit(1)
Path(store).write_text(json.dumps(d, indent=2))
EOF
    echo -e "  ${GREEN}✓${NC}  '$name' deleted and removed from cron"
    ;;

  *)
    echo "Usage: axis sched add|list|log|run|pause|resume|del <args>"
    exit 1
    ;;
esac
