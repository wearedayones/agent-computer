#!/bin/bash
# skill — local skill registry (Agent Computer v4)
# Skills live in ~/skills/ as executable Markdown files.
# Usage: skill list
#        skill add <name>
#        skill show <name>
#        skill search <query>
#        skill del <name>

SKILLS_DIR="$HOME/skills"
mkdir -p "$SKILLS_DIR"

BOLD='\033[1m'; CYAN='\033[0;36m'; GREEN='\033[0;32m'
YELLOW='\033[1;33m'; DIM='\033[2m'; NC='\033[0m'

resolve() {
  local name="$1"
  if [ -f "$SKILLS_DIR/$name.md" ]; then echo "$SKILLS_DIR/$name.md"
  elif [ -f "$SKILLS_DIR/$name" ]; then echo "$SKILLS_DIR/$name"
  else echo ""
  fi
}

cmd="${1:-list}"

case "$cmd" in
  list)
    files=("$SKILLS_DIR"/*.md)
    if [ ! -f "${files[0]}" ]; then
      echo -e "\n  (no skills installed — add with: axis skill add <name>)\n"
      exit 0
    fi
    echo ""
    echo -e "  ${BOLD}Skills in ~/skills/${NC}\n"
    printf "  %-24s  %-10s  %s\n" "NAME" "VERSION" "DESCRIPTION"
    echo "  ──────────────────────────────────────────────────────────────"
    for f in "$SKILLS_DIR"/*.md; do
      [ -f "$f" ] || continue
      name="$(basename "$f" .md)"
      desc=$(grep -m1 '^>' "$f" 2>/dev/null | sed 's/^> //')
      version=$(grep -m1 '^> Version:' "$f" 2>/dev/null | sed 's/^> Version: //')
      [ -z "$version" ] && version="-"
      printf "  ${CYAN}%-24s${NC}  ${DIM}%-10s${NC}  %s\n" "$name" "$version" "${desc:-}"
    done
    echo ""
    ;;

  add)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis skill add <name>"; exit 1; }
    path="$SKILLS_DIR/$name.md"
    if [ -f "$path" ]; then
      echo -e "  ${YELLOW}⚠${NC}  $name already exists — edit it at ~/skills/$name.md"
      exit 1
    fi
    cat > "$path" <<TEMPLATE
# $name
> One-line description of what this skill does.
> Tags: general
> Version: 1.0.0

## When to Use
Describe the scenario or trigger that makes this skill relevant.

## Constraints
- List any hard limits or safety rules here.
- Example: Never place real-money trades without confirmation.
- Check trace history first: \`axis trace search "$name"\`

## Steps
1. First step — be specific about commands and expected output.
2. Second step.
3. Log the outcome: \`axis trace log "<what you did>" --outcome success --tags $name\`

## Notes
Any context, background knowledge, or links relevant to this skill.
TEMPLATE
    echo -e "  ${GREEN}✓${NC}  Created ~/skills/$name.md"
    echo -e "  ${DIM}Edit it to fill in the steps, then: axis skill show $name${NC}"
    ;;

  show)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis skill show <name>"; exit 1; }
    path=$(resolve "$name")
    if [ -z "$path" ]; then
      echo -e "  (skill '$name' not found — list with: axis skill list)"
      exit 1
    fi
    echo ""
    cat "$path" | sed 's/^/  /'
    echo ""
    ;;

  search)
    query="${2:-}"
    [ -z "$query" ] && { echo "Usage: axis skill search <query>"; exit 1; }
    files=("$SKILLS_DIR"/*.md)
    if [ ! -f "${files[0]}" ]; then
      echo "  (no skills installed)"; exit 0
    fi
    echo ""
    found=0
    for f in "$SKILLS_DIR"/*.md; do
      [ -f "$f" ] || continue
      if grep -qi "$query" "$f" 2>/dev/null; then
        name="$(basename "$f" .md)"
        desc=$(grep -m1 '^>' "$f" 2>/dev/null | sed 's/^> //')
        echo -e "  ${CYAN}$name${NC}  ${DIM}$desc${NC}"
        found=1
      fi
    done
    [ "$found" -eq 0 ] && echo "  (no skills matching '$query')"
    echo ""
    ;;

  del|delete|rm)
    name="${2:-}"
    [ -z "$name" ] && { echo "Usage: axis skill del <name>"; exit 1; }
    path=$(resolve "$name")
    if [ -z "$path" ]; then
      echo "  (skill '$name' not found)"; exit 1
    fi
    rm "$path"
    echo -e "  ${GREEN}✓${NC}  Deleted ~/skills/$name.md"
    ;;

  *)
    echo "Usage: axis skill list|add|show|search|del <name>"
    exit 1
    ;;
esac
