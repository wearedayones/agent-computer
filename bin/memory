#!/bin/bash
# memory — persistent cross-session knowledge store
# Usage: memory set <key> <value>
#        memory get <key>
#        memory list
#        memory del <key>

STORE="$HOME/system/memory.json"
[ -f "$STORE" ] || echo '{}' > "$STORE"

cmd="${1:-list}"

case "$cmd" in
  set)
    [ -z "$2" ] && { echo "Usage: memory set <key> <value>"; exit 1; }
    key="$2"; shift 2; value="$*"
    python3 - "$STORE" "$key" "$value" <<'EOF'
import json, sys
store, key, value = sys.argv[1], sys.argv[2], sys.argv[3]
with open(store) as f: d = json.load(f)
d[key] = value
with open(store, "w") as f: json.dump(d, f, indent=2)
print(f"  \033[32m✓\033[0m  {key} saved")
EOF
    ;;
  get)
    [ -z "$2" ] && { echo "Usage: memory get <key>"; exit 1; }
    python3 - "$STORE" "$2" <<'EOF'
import json, sys
with open(sys.argv[1]) as f: d = json.load(f)
v = d.get(sys.argv[2])
if v is None: print("  (not found)"); sys.exit(1)
print(v)
EOF
    ;;
  list)
    python3 - "$STORE" <<'EOF'
import json, sys
with open(sys.argv[1]) as f: d = json.load(f)
if not d: print("  (no memories stored)"); sys.exit(0)
maxk = max(len(k) for k in d)
for k, v in d.items():
    print(f"  \033[36m{k:<{maxk}}\033[0m  {v}")
EOF
    ;;
  del|delete|rm)
    [ -z "$2" ] && { echo "Usage: memory del <key>"; exit 1; }
    python3 - "$STORE" "$2" <<'EOF'
import json, sys
with open(sys.argv[1]) as f: d = json.load(f)
if sys.argv[2] not in d: print("  (not found)"); sys.exit(1)
del d[sys.argv[2]]
with open(sys.argv[1], "w") as f: json.dump(d, f, indent=2)
print(f"  \033[32m✓\033[0m  {sys.argv[2]} deleted")
EOF
    ;;
  *)
    echo "Usage: memory set|get|list|del <key> [value]"
    exit 1
    ;;
esac
