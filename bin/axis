#!/bin/bash
# axis — Agent Computer CLI
# The single command that IS your computer.
# Usage: axis [command] [args...]

BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAGENTA='\033[0;35m'
WHITE='\033[1;37m'

VERSION=$(cat "$HOME/system/.version" 2>/dev/null || echo "?")
HOME_DIR="$HOME"

# ── Status dashboard (default) ────────────────────────────────────────────────
cmd_status() {
  local NOW
  NOW=$(date -u '+%Y-%m-%d %H:%M UTC')

  # Collect data
  local DISK_FREE DISK_PCT DISK_FREE_GB
  DISK_FREE=$(df -h "$HOME_DIR" | awk 'NR==2{print $4}')
  DISK_PCT=$(df "$HOME_DIR" | awk 'NR==2{print $5}')
  DISK_FREE_GB=$(df -BG "$HOME_DIR" | awk 'NR==2{gsub("G","",$4); print $4}')

  local SESSIONS CRON_COUNT INBOX_COUNT
  SESSIONS=$(tmux ls 2>/dev/null | awk -F: '{print $1}' | tr '\n' ' ' | sed 's/ $//' || echo "none")
  CRON_COUNT=$(crontab -l 2>/dev/null | grep -v "^#" | grep -v "^$" | wc -l | tr -d ' ')
  INBOX_COUNT=$(find "$HOME_DIR/inbox/" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ')

  local OPEN_TASKS TASK_LIST PLAN_TITLE BUDGET_MONTH
  OPEN_TASKS=0; TASK_LIST=""; PLAN_TITLE=""

  if [ -f "$HOME_DIR/system/tasks.json" ]; then
    OPEN_TASKS=$(python3 -c "
import json
with open('$HOME_DIR/system/tasks.json') as f: d=json.load(f)
tasks=[t for t in d.get('tasks',[]) if t.get('status')=='open']
print(len(tasks))
" 2>/dev/null | tr -d ' \n')
    [ -z "$OPEN_TASKS" ] && OPEN_TASKS=0
    if [ "$OPEN_TASKS" -gt 0 ]; then
      TASK_LIST=$(python3 -c "
import json
with open('$HOME_DIR/system/tasks.json') as f: d=json.load(f)
for t in d.get('tasks',[]):
    if t.get('status')=='open':
        print(f\"  {t['id']:>3}  {t['desc']}\")
" 2>/dev/null)
    fi
  fi

  if [ -f "$HOME_DIR/system/plan.md" ]; then
    PLAN_TITLE=$(head -1 "$HOME_DIR/system/plan.md" | sed 's/^# Plan: //')
  fi

  BUDGET_MONTH=$(python3 -c "
import json
from datetime import datetime, timezone
try:
  with open('$HOME_DIR/system/budget.json') as f: d=json.load(f)
  m=datetime.now(timezone.utc).strftime('%Y-%m')
  total=sum(e['amount'] for e in d.get('entries',[]) if e.get('month')==m)
  print(f'\${total:.4f}') if total else print('none')
except: print('none')
" 2>/dev/null)

  local AGENT_STATUS=""
  if [ -f "$HOME_DIR/system/agents.json" ]; then
    AGENT_STATUS=$(python3 - "$HOME_DIR/system/agents.json" <<'EOF'
import json, sys, subprocess
with open(sys.argv[1]) as f: d = json.load(f)
agents = d.get("agents", {})
if not agents: print("none registered"); sys.exit()
parts = []
for name, info in agents.items():
    check = info.get("check", "")
    if check:
        r = subprocess.run(check, shell=True, capture_output=True)
        dot = "\033[32m●\033[0m" if r.returncode == 0 else "\033[31m○\033[0m"
    else:
        dot = "\033[33m?\033[0m"
    parts.append(f"{dot} {name}")
print("  ".join(parts))
EOF
)
  fi

  local MEMORY_COUNT=0
  [ -f "$HOME_DIR/system/memory.json" ] && \
    MEMORY_COUNT=$(python3 -c "import json; d=json.load(open('$HOME_DIR/system/memory.json')); print(len(d))" 2>/dev/null || echo 0)

  # ── Render ────────────────────────────────────────────────────────────────
  echo ""
  echo -e "${BOLD}${CYAN}  ╔══════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}${CYAN}  ║${NC}  ${WHITE}${BOLD}AXIS${NC}  ${DIM}v${VERSION}${NC}  ·  ${DIM}Agent Computer${NC}  ${BOLD}${CYAN}               ║${NC}"
  echo -e "${BOLD}${CYAN}  ║${NC}  ${DIM}${NOW}${NC}  ${BOLD}${CYAN}                             ║${NC}"
  echo -e "${BOLD}${CYAN}  ╚══════════════════════════════════════════════════════╝${NC}"
  echo ""

  # System
  echo -e "  ${BOLD}${BLUE}System${NC}"
  local disk_color="$NC"
  [ "${DISK_FREE_GB:-99}" -lt 2 ] 2>/dev/null && disk_color="$RED"
  [ "${DISK_FREE_GB:-99}" -lt 4 ] 2>/dev/null && [ "${DISK_FREE_GB:-99}" -ge 2 ] 2>/dev/null && disk_color="$YELLOW"
  echo -e "    Disk       ${disk_color}${DISK_FREE} free (${DISK_PCT} used)${NC}"
  [ -n "$SESSIONS" ] && echo -e "    Sessions   ${GREEN}${SESSIONS}${NC}" || echo -e "    Sessions   ${DIM}none${NC}"
  echo -e "    Cron       ${CRON_COUNT} active jobs"
  echo ""

  # Work
  echo -e "  ${BOLD}${BLUE}Work${NC}"
  if [ "$INBOX_COUNT" -gt 0 ]; then
    echo -e "    Inbox      ${YELLOW}${INBOX_COUNT} message(s) — axis note list${NC}"
  else
    echo -e "    Inbox      ${DIM}empty${NC}"
  fi
  if [ "$OPEN_TASKS" -gt 0 ]; then
    echo -e "    Tasks      ${YELLOW}${OPEN_TASKS} open${NC}"
    echo "$TASK_LIST" | sed 's/^/  /' | head -5
  else
    echo -e "    Tasks      ${DIM}none${NC}"
  fi
  if [ -n "$PLAN_TITLE" ]; then
    echo -e "    Plan       ${CYAN}${PLAN_TITLE}${NC}"
  else
    echo -e "    Plan       ${DIM}none${NC}"
  fi
  echo -e "    Budget     ${DIM}${BUDGET_MONTH} this month${NC}"
  echo -e "    Memory     ${MEMORY_COUNT} stored facts"
  echo ""

  # Agents
  echo -e "  ${BOLD}${BLUE}Agents${NC}"
  if [ -n "$AGENT_STATUS" ]; then
    echo -e "    ${AGENT_STATUS}"
  else
    echo -e "    ${DIM}none registered${NC}"
  fi
  echo ""

  # Quick
  echo -e "  ${DIM}axis boot · axis check · axis task list · axis help${NC}"
  echo ""
}

# ── Help ──────────────────────────────────────────────────────────────────────
cmd_help() {
  local topic="${1:-}"

  if [ -n "$topic" ]; then
    # Delegate to underlying command's help
    if command -v "$topic" &>/dev/null; then
      "$topic" --help 2>/dev/null || "$topic" 2>/dev/null || true
    else
      echo "  No help found for '$topic'"
    fi
    return
  fi

  echo ""
  echo -e "${BOLD}${CYAN}  AXIS v${VERSION} — Agent Computer CLI${NC}"
  echo -e "  ${DIM}Usage: axis <command> [args...]${NC}"
  echo ""
  echo -e "  ${BOLD}${BLUE}Session${NC}"
  echo -e "    ${CYAN}boot${NC}                     Start session — reads inbox, shows pulse"
  echo -e "    ${CYAN}check${NC}                    Full health report"
  echo -e "    ${CYAN}map${NC}                      Refresh README.md from live state"
  echo -e "    ${CYAN}update${NC}                   Pull latest computer from GitHub"
  echo ""
  echo -e "  ${BOLD}${BLUE}Work Queue${NC}"
  echo -e "    ${CYAN}task add${NC} \"desc\"           Add a task"
  echo -e "    ${CYAN}task list${NC}                Show open tasks"
  echo -e "    ${CYAN}task done${NC} <id>            Mark task complete"
  echo -e "    ${CYAN}task clear${NC}               Remove all done tasks"
  echo -e "    ${CYAN}plan set${NC} \"title\"          Start a session plan"
  echo -e "    ${CYAN}plan add${NC} \"step\"           Add a step"
  echo -e "    ${CYAN}plan show${NC}                Show active plan"
  echo ""
  echo -e "  ${BOLD}${BLUE}Memory & State${NC}"
  echo -e "    ${CYAN}memory set${NC} key \"value\"    Persist a fact across sessions"
  echo -e "    ${CYAN}memory get${NC} key            Recall a fact"
  echo -e "    ${CYAN}memory list${NC}              Show all stored memories"
  echo -e "    ${CYAN}budget log${NC} 0.05 \"desc\"    Record a spend entry"
  echo -e "    ${CYAN}budget show${NC}              Show this month's spend"
  echo -e "    ${CYAN}snapshot${NC}                 Archive state to ~/archive/"
  echo ""
  echo -e "  ${BOLD}${BLUE}Inbox & Messaging${NC}"
  echo -e "    ${CYAN}note${NC} \"message\"            Leave a message for next agent"
  echo -e "    ${CYAN}note list${NC}                Show inbox summaries"
  echo -e "    ${CYAN}note read${NC}                Read full inbox"
  echo -e "    ${CYAN}note clear${NC}               Remove all messages"
  echo -e "    ${CYAN}msg${NC} <agent> \"text\"        Message a specific agent's inbox"
  echo ""
  echo -e "  ${BOLD}${BLUE}Apps & Logs${NC}"
  echo -e "    ${CYAN}run list${NC}                 Show runnable apps"
  echo -e "    ${CYAN}run${NC} <app>                Start an app"
  echo -e "    ${CYAN}watch${NC} <app>              Tail all logs for an app"
  echo -e "    ${CYAN}watch${NC} <app> list         Show available logs"
  echo -e "    ${CYAN}cfg list${NC}                 Show apps with .env files"
  echo -e "    ${CYAN}cfg set${NC} <app> KEY val    Set a config value"
  echo -e "    ${CYAN}cfg show${NC} <app>           Print full .env"
  echo -e "    ${CYAN}log today${NC}                Today's activity"
  echo -e "    ${CYAN}log errors${NC}               Errors only"
  echo ""
  echo -e "  ${BOLD}${BLUE}Registry${NC}"
  echo -e "    ${CYAN}agent list${NC}               Show registered agents + live status"
  echo -e "    ${CYAN}agent add${NC} name \"desc\"     Register an agent"
  echo -e "    ${CYAN}agent ping${NC} <name>         Check if an agent is alive"
  echo -e "    ${CYAN}mcp list${NC}                 Show configured MCP servers"
  echo -e "    ${CYAN}mcp add${NC} name cmd [args]   Add an MCP server"
  echo -e "    ${CYAN}mcp status${NC}               Check which MCP commands are installed"
  echo -e "    ${CYAN}cron list${NC}                Show cron jobs by number"
  echo -e "    ${CYAN}cron add${NC} \"sched\" \"cmd\"    Add a cron job"
  echo -e "    ${CYAN}cron del${NC} <n>              Remove cron job #n"
  echo ""
  echo -e "  ${BOLD}${BLUE}Security & Migration${NC}"
  echo -e "    ${CYAN}secret list${NC}              Show key names in ~/keys/"
  echo -e "    ${CYAN}secret get${NC} <name>         Read a key"
  echo -e "    ${CYAN}export${NC}                   Package computer for migration"
  echo -e "    ${CYAN}export --include-secrets${NC}  Full export with keys"
  echo ""
  echo -e "  ${BOLD}${BLUE}Axiom${NC}"
  echo -e "    ${CYAN}axis${NC}                    Status dashboard"
  echo -e "    ${CYAN}axis version${NC}            Show version"
  echo -e "    ${CYAN}axis help${NC} [command]      This help, or help for a command"
  echo ""
}

# ── Version ───────────────────────────────────────────────────────────────────
cmd_version() {
  echo ""
  echo -e "  ${BOLD}AXIS${NC}  v${VERSION}"
  echo -e "  ${DIM}Agent Computer — wearedayones/agent-computer${NC}"
  echo -e "  ${DIM}Installed: $(cat "$HOME_DIR/system/.installed" 2>/dev/null | grep "Installed" | sed 's/.*Installed : //' | xargs)${NC}"
  echo ""
}

# ── Delegate to underlying command ───────────────────────────────────────────
cmd_delegate() {
  local cmd="$1"; shift
  if command -v "$cmd" &>/dev/null; then
    exec "$cmd" "$@"
  elif [ -f "$HOME_DIR/bin/$cmd" ]; then
    exec bash "$HOME_DIR/bin/$cmd" "$@"
  else
    echo ""
    echo -e "  ${RED}axis: unknown command '$cmd'${NC}"
    echo -e "  ${DIM}Run 'axis help' to see available commands${NC}"
    echo ""
    exit 1
  fi
}

# ── Router ────────────────────────────────────────────────────────────────────
case "${1:-}" in
  ""|status)      cmd_status ;;
  help)           shift; cmd_help "$@" ;;
  version|--version|-v) cmd_version ;;
  *)              cmd_delegate "$@" ;;
esac
