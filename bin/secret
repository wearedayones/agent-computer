#!/bin/bash
# secret — safe read access to ~/keys/
# Usage: secret list            — show key names (never values)
#        secret get <name>      — print key value to stdout
#        secret set <name>      — prompt to write (input hidden)
#        secret del <name>      — remove a key file

KEYS="$HOME/keys"
mkdir -p "$KEYS"

resolve() {
  local name="$1"
  if [ -f "$KEYS/$name" ]; then
    echo "$KEYS/$name"
  elif [ -f "$KEYS/$name.txt" ]; then
    echo "$KEYS/$name.txt"
  else
    echo ""
  fi
}

cmd="${1:-list}"

case "$cmd" in
  list)
    files=$(ls "$KEYS" 2>/dev/null)
    if [ -z "$files" ]; then
      echo "  (no keys stored)"; exit 0
    fi
    echo ""
    echo "  Keys in ~/keys/"
    echo "  ──────────────────────────────────────────"
    while IFS= read -r f; do
      size=$(wc -c < "$KEYS/$f" 2>/dev/null | tr -d ' ')
      echo "  $f  (${size}B)"
    done <<< "$files"
    echo ""
    ;;

  get)
    [ -z "$2" ] && { echo "Usage: secret get <name>"; exit 1; }
    path=$(resolve "$2")
    if [ -z "$path" ]; then
      echo "  (not found: $2)" >&2; exit 1
    fi
    cat "$path"
    ;;

  set)
    [ -z "$2" ] && { echo "Usage: secret set <name>"; exit 1; }
    name="$2"
    path="$KEYS/$name"
    echo -n "  Value for '$name' (input hidden): " >&2
    read -rs value
    echo "" >&2
    [ -z "$value" ] && { echo "  (empty — aborted)" >&2; exit 1; }
    printf '%s' "$value" > "$path"
    chmod 600 "$path"
    echo "  ✓  $name saved (${#value}B)"
    ;;

  del|delete|rm)
    [ -z "$2" ] && { echo "Usage: secret del <name>"; exit 1; }
    path=$(resolve "$2")
    if [ -z "$path" ]; then
      echo "  (not found: $2)" >&2; exit 1
    fi
    rm "$path"
    echo "  ✓  $2 deleted"
    ;;

  *)
    echo "Usage: secret list|get|set|del <name>"
    exit 1
    ;;
esac
