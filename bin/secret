#!/bin/bash
# secret — safe access to ~/keys/ (v2: expiry, rotation, categories, audit)
# Usage: secret list [--category name]
#        secret get <name>
#        secret set <name> [--expires YYYY-MM-DD] [--category name]
#        secret rotate <name>
#        secret audit
#        secret del <name>

KEYS="$HOME/keys"
META="$KEYS/.meta.json"
mkdir -p "$KEYS"
[ -f "$META" ] || echo '{}' > "$META"
chmod 600 "$META" 2>/dev/null || true

resolve() {
  local name="$1"
  if [ -f "$KEYS/$name" ]; then
    echo "$KEYS/$name"
  elif [ -f "$KEYS/$name.txt" ]; then
    echo "$KEYS/$name.txt"
  else
    echo ""
  fi
}

cmd="${1:-list}"

case "$cmd" in
  list)
    shift
    filter_cat=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --category) filter_cat="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    python3 - "$KEYS" "$META" "$filter_cat" <<'EOF'
import json, sys, os
from datetime import datetime, timezone, timedelta
keys_dir, meta_f, filter_cat = sys.argv[1:4]
try:
    with open(meta_f) as f: meta = json.load(f)
except: meta = {}
files = sorted([f for f in os.listdir(keys_dir) if not f.startswith(".")])
if filter_cat:
    files = [f for f in files if meta.get(f,{}).get("category","") == filter_cat]
if not files:
    print("  (no keys stored)"); sys.exit(0)
GREEN, RED, YELLOW, BOLD, NC = "\033[0;32m", "\033[0;31m", "\033[1;33m", "\033[1m", "\033[0m"
now = datetime.now(timezone.utc)
warn_dt = now + timedelta(days=30)
print(f"\n  Keys in ~/keys/\n")
print(f"  {'─'*55}")
for f in files:
    path = os.path.join(keys_dir, f)
    size = os.path.getsize(path)
    m = meta.get(f, {})
    cat = m.get("category","")
    expires = m.get("expires","")
    cat_str = f"  [{cat}]" if cat else ""
    exp_str = ""
    exp_color = NC
    if expires:
        try:
            exp_dt = datetime.fromisoformat(expires)
            if exp_dt.tzinfo is None:
                exp_dt = exp_dt.replace(tzinfo=timezone.utc)
            if exp_dt < now:
                exp_str = f"  {RED}EXPIRED {expires}{NC}"
            elif exp_dt < warn_dt:
                exp_str = f"  {YELLOW}expires {expires}{NC}"
            else:
                exp_str = f"  expires {expires}"
        except: exp_str = f"  expires {expires}"
    print(f"  {f:<30} {size}B{cat_str}{exp_str}")
print("")
EOF
    ;;

  get)
    [ -z "$2" ] && { echo "Usage: secret get <name>"; exit 1; }
    path=$(resolve "$2")
    if [ -z "$path" ]; then
      echo "  (not found: $2)" >&2; exit 1
    fi
    cat "$path"
    ;;

  set)
    [ -z "$2" ] && { echo "Usage: secret set <name> [--expires YYYY-MM-DD] [--category name]"; exit 1; }
    name="$2"; shift 2
    expires=""
    category=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --expires)  expires="$2";  shift 2 ;;
        --category) category="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    path="$KEYS/$name"
    echo -n "  Value for '$name' (input hidden): " >&2
    read -rs value
    echo "" >&2
    [ -z "$value" ] && { echo "  (empty — aborted)" >&2; exit 1; }
    printf '%s' "$value" > "$path"
    chmod 600 "$path"
    # Update metadata
    python3 - "$META" "$name" "$expires" "$category" <<'EOF'
import json, sys
meta_f, name, expires, category = sys.argv[1:5]
try:
    with open(meta_f) as f: meta = json.load(f)
except: meta = {}
meta.setdefault(name, {})
if expires: meta[name]["expires"] = expires
if category: meta[name]["category"] = category
with open(meta_f, "w") as f: json.dump(meta, f, indent=2)
EOF
    extras=""
    [ -n "$expires" ] && extras+="  expires: $expires"
    [ -n "$category" ] && extras+="  category: $category"
    echo "  ✓  $name saved (${#value}B)$extras"
    ;;

  rotate)
    [ -z "$2" ] && { echo "Usage: secret rotate <name>"; exit 1; }
    name="$2"
    path=$(resolve "$name")
    if [ -z "$path" ]; then
      echo "  (not found: $name)" >&2; exit 1
    fi
    # Archive old value
    ts=$(date -u +%Y%m%d%H%M%S)
    archive_path="$KEYS/.archive-${name}-${ts}"
    cp "$path" "$archive_path"
    chmod 600 "$archive_path"
    echo -n "  New value for '$name' (input hidden): " >&2
    read -rs value
    echo "" >&2
    [ -z "$value" ] && { echo "  (empty — aborted, old value preserved)" >&2; rm -f "$archive_path"; exit 1; }
    printf '%s' "$value" > "$path"
    chmod 600 "$path"
    # Update rotation metadata
    python3 - "$META" "$name" "$ts" <<'EOF'
import json, sys
from datetime import datetime, timezone
meta_f, name, ts = sys.argv[1:4]
try:
    with open(meta_f) as f: meta = json.load(f)
except: meta = {}
meta.setdefault(name, {})
meta[name]["last_rotated"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
meta[name].pop("expires", None)
with open(meta_f, "w") as f: json.dump(meta, f, indent=2)
EOF
    echo "  ✓  $name rotated (old value archived as .archive-${name}-${ts})"
    ;;

  audit)
    python3 - "$KEYS" "$META" <<'EOF'
import json, sys, os
from datetime import datetime, timezone, timedelta
keys_dir, meta_f = sys.argv[1:3]
try:
    with open(meta_f) as f: meta = json.load(f)
except: meta = {}
files = sorted([f for f in os.listdir(keys_dir) if not f.startswith(".")])
now = datetime.now(timezone.utc)
warn_dt = now + timedelta(days=30)
expired = []
expiring = []
no_meta = []
GREEN, RED, YELLOW, BOLD, NC = "\033[0;32m", "\033[0;31m", "\033[1;33m", "\033[1m", "\033[0m"
for f in files:
    m = meta.get(f, {})
    expires = m.get("expires","")
    if not expires:
        no_meta.append(f)
        continue
    try:
        exp_dt = datetime.fromisoformat(expires)
        if exp_dt.tzinfo is None: exp_dt = exp_dt.replace(tzinfo=timezone.utc)
        if exp_dt < now:
            expired.append((f, expires))
        elif exp_dt < warn_dt:
            expiring.append((f, expires))
    except: pass

print(f"\n  {BOLD}Secret Audit{NC}\n")
if expired:
    print(f"  {RED}EXPIRED ({len(expired)}):{NC}")
    for f, d in expired:
        print(f"    ✗  {f}  (expired {d})")
if expiring:
    print(f"  {YELLOW}Expiring within 30 days ({len(expiring)}):{NC}")
    for f, d in expiring:
        print(f"    ⚠  {f}  (expires {d})")
if not expired and not expiring:
    print(f"  {GREEN}No keys expiring within 30 days.{NC}")
print(f"\n  Total keys: {len(files)}  ·  With expiry metadata: {len(files)-len(no_meta)}  ·  Without: {len(no_meta)}")
print("")
EOF
    ;;

  del|delete|rm)
    [ -z "$2" ] && { echo "Usage: secret del <name>"; exit 1; }
    path=$(resolve "$2")
    if [ -z "$path" ]; then
      echo "  (not found: $2)" >&2; exit 1
    fi
    rm "$path"
    # Clean up metadata
    python3 - "$META" "$2" <<'EOF' 2>/dev/null || true
import json, sys
meta_f, name = sys.argv[1:3]
try:
    with open(meta_f) as f: meta = json.load(f)
    meta.pop(name, None)
    with open(meta_f, "w") as f: json.dump(meta, f, indent=2)
except: pass
EOF
    echo "  ✓  $2 deleted"
    ;;

  *)
    echo "Usage: secret list|get|set|rotate|audit|del <name>"
    exit 1
    ;;
esac
